POSTGRES_DB=sua_airspace
POSTGRES_USER=sua_airspace
POSTGRES_PASSWORD=replace-with-a-long-random-password
SITE_PORT=8080
PUBLIC_BASE_URL=https://sua.example.vatpac.org
TRUST_PROXY=true

# Protects only POST /api/automation/refresh; the current plugin sync protocol does not send this token.
SUA_SYNC_TOKEN=replace-with-a-separate-long-random-token

DISCORD_REQUEST_WEBHOOK_URL=

# Leave false until the VATSIM OAuth application is registered.
VATSIM_AUTH_REQUIRED=false
VATSIM_CLIENT_ID=
VATSIM_CLIENT_SECRET=
VATSIM_REDIRECT_URI=https://sua.example.vatpac.org/api/auth/callback
AUTHORIZED_VATSIM_CIDS=

AUTOMATION_ENABLED=true
AUTOMATION_INTERVAL_SECONDS=60
AUTOMATION_RUN_ON_START=true
